PROJECT_NAME=mockly

# Domains (must point to the EC2 public IP)
API_DOMAIN=api.iness.app
ML_DOMAIN=ai.iness.app
LIVEKIT_DOMAIN=rtc.iness.app
MINIO_DOMAIN=minio.iness.app
ACME_EMAIL=CHANGE_ME_EMAIL@example.com

# App profile
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL
DB_NAME=mockly
DB_USER=mockly
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# MinIO
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=mockly-artifacts

# JWT
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# LiveKit
LIVEKIT_API_KEY=CHANGE_ME_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=CHANGE_ME_LIVEKIT_SECRET
LIVEKIT_WEBHOOK_SECRET=CHANGE_ME_SAME_AS_LIVEKIT_API_SECRET
LIVEKIT_EGRESS_WEBHOOK_SIGNING_KEY=CHANGE_ME_SAME_AS_LIVEKIT_API_SECRET
LIVEKIT_EGRESS_AUTO_RECORD=false
LIVEKIT_EGRESS_FILE_TYPE=MP3

# AI / Ollama
OLLAMA_ENABLED=true
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_TIMEOUT_SECONDS=60
